# SPCS Endpoint URLs
# After creating the service, run:
#   SHOW ENDPOINTS IN SERVICE RETAIL_ANALYZER.PUBLIC.RETAIL_ANALYZER_SVC;
# and copy the ingress_url for each endpoint below.

GOOGLE_SHOPPING_API_URL=https://<ingress_url_for_google-shopping>
GRAILED_API_URL=https://<ingress_url_for_grailed>
VESTIAIRE_API_URL=https://<ingress_url_for_vestiaire>
REBAG_API_URL=https://<ingress_url_for_rebag>
FARFETCH_API_URL=https://<ingress_url_for_farfetch>
FASHIONPHILE_API_URL=https://<ingress_url_for_fashionphile>
SECONDSTREET_API_URL=https://<ingress_url_for_secondstreet>

# Programmatic Access Token for authenticating to SPCS endpoints.
# Create one in the Snowflake web UI: User Profile > Programmatic Access Tokens
SNOWFLAKE_PAT=<your_programmatic_access_token>
