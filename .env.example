# Snowflake credentials
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# Option A: file path (local dev)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/snowflake_rsa_key.p8

# Option B: base64-encoded PEM key (production / Docker / ECS)
# Generate with: cat snowflake_rsa_key.p8 | base64 | tr -d '\n'
# SNOWFLAKE_PRIVATE_KEY_B64=LS0tLS1CRUdJTi...

# Redis
REDIS_URL=redis://localhost:6379/0

# Marketplace API URLs (change these when deploying to production)
GOOGLE_SHOPPING_API_URL=http://localhost:8000
GRAILED_API_URL=http://localhost:8001
VESTIAIRE_API_URL=http://localhost:8002
REBAG_API_URL=http://localhost:8003
FARFETCH_API_URL=http://localhost:8004
FASHIONPHILE_API_URL=http://localhost:8005
SECONDSTREET_API_URL=http://localhost:8006
