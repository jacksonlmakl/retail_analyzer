# Snowflake credentials
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/snowflake_rsa_key.p8
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# Redis (override only if using external Redis)
# REDIS_URL=redis://redis:6379/0

# API URL (used by Airflow to trigger tasks; override for cross-cloud deployment)
RETAIL_API_URL=http://api:8000

# Verification schedule
VERIFY_INTERVAL_HOURS=24
VERIFY_STALE_DAYS=7
